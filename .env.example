# Internet Toolkit — Environment Configuration Template
# Copy this file to .env.dev (development) or .env.prod (production)
# and fill in real values. Never commit either file.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=toolkit
POSTGRES_USER=toolkit
POSTGRES_PASSWORD=change_me_in_prod

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
# Secret key used for JWT signing — generate with: openssl rand -hex 32
SECRET_KEY=change_me_in_prod

# "development" or "production"
ENVIRONMENT=development

# Allowed CORS origins as a JSON array.
# Development: include localhost variants.
# Production: set to your actual domain, e.g. ["https://yourdomain.com"]
CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# ---------------------------------------------------------------------------
# Database URL — must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# The hostname "postgres" is the Docker Compose service name (internal network).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://toolkit:change_me_in_prod@postgres:5432/toolkit
