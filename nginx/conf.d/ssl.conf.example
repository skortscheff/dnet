# HTTPS / TLS configuration example for Internet Toolkit
#
# HOW TO USE:
# 1. Obtain certificates for your domain (e.g. with Certbot):
#      apt install certbot
#      certbot certonly --standalone -d yourdomain.com
#    This writes certs to /etc/letsencrypt/live/yourdomain.com/
#
# 2. Mount the certs into the nginx container by adding to compose.prod.yaml:
#      nginx:
#        volumes:
#          - /etc/letsencrypt:/etc/letsencrypt:ro
#
# 3. Copy this file to nginx/conf.d/default.conf (replacing the HTTP-only version):
#      cp nginx/conf.d/ssl.conf.example nginx/conf.d/default.conf
#
# 4. Update the two occurrences of "yourdomain.com" below, then deploy.
#
# Auto-renewal: add a cron job or systemd timer to run:
#   certbot renew --pre-hook "docker compose -f compose.yaml -f compose.prod.yaml stop nginx" \
#                 --post-hook "docker compose -f compose.yaml -f compose.prod.yaml start nginx"

resolver 127.0.0.11 valid=10s ipv6=off;

# Redirect all HTTP to HTTPS
server {
    listen 80;
    server_name yourdomain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name yourdomain.com;

    ssl_certificate     /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;

    # Modern SSL settings (TLS 1.2 + 1.3 only)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # HSTS (enable once HTTPS is confirmed working)
    # add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;

    # Search endpoint — stricter rate limit (must come before /api/)
    location = /api/v1/search {
        limit_req zone=search_limit burst=5 nodelay;
        set $api_upstream http://api:8000;
        proxy_pass $api_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # API proxy
    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;
        set $api_upstream http://api:8000;
        proxy_pass $api_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
    }

    # Frontend proxy
    location / {
        set $frontend_upstream http://frontend:3000;
        proxy_pass $frontend_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 60s;
    }
}
